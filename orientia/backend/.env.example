# --- Supabase (Settings > API in your Supabase project) ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # server-side only, keep secret
SUPABASE_ANON_KEY=your-anon-key

# --- LLM provider: "groq" (free tier) or "openai" ---
LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-key
OPENAI_API_KEY=   # only needed if LLM_PROVIDER=openai — leave blank for groq

# Embeddings run locally via sentence-transformers — no key needed, free.

# --- App ---
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]
MAX_UPLOAD_MB=15
